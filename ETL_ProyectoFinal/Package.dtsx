  <DTS:Variables>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{21555C7C-D42F-4DEF-9BE0-425FA288A946}"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="SQL_DimTiempo">
      <DTS:VariableValue
        DTS:DataType="8">SELECT     ROW_NUMBER() OVER (ORDER BY fecha_pedido, metodo_pago) AS id_tiempo,     DATE(fecha_pedido) AS fecha_completa,     EXTRACT(YEAR FROM fecha_pedido) AS anio,     EXTRACT(MONTH FROM fecha_pedido) AS mes,     TO_CHAR(fecha_pedido, 'Month') AS nombre_mes,     TO_CHAR(fecha_pedido, 'Day') AS dia_semana,     CASE          WHEN EXTRACT(HOUR FROM fecha_pedido) BETWEEN 6 AND 11 THEN 'Mañana'         WHEN EXTRACT(HOUR FROM fecha_pedido) BETWEEN 12 AND 17 THEN 'Tarde'         WHEN EXTRACT(HOUR FROM fecha_pedido) BETWEEN 18 AND 23 THEN 'Noche'         ELSE 'Madrugada'     END AS turno,     metodo_pago FROM (     SELECT DISTINCT fecha_pedido, metodo_pago     FROM Pedidos ) AS distinct_fechas ORDER BY fecha_pedido, metodo_pago;</DTS:VariableValue>
    </DTS:Variable>
  </DTS:Variables>
